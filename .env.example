# ============================================================
# K-RoadTrip environment variables
# Copy to .env.local for local dev; on Vercel, set these in
# Project Settings → Environment Variables (all three are
# NEXT_PUBLIC_* — safe to expose, protected by RLS / referrer
# restrictions, NOT secrets like service_role).
# ============================================================

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Cloud Console → Maps JavaScript API key
# (restrict by HTTP referrer to your domains!)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
